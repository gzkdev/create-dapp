{
  "name": "create-dapp",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format:write": "turbo format:write",
    "format:check": "turbo format:check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build --filter=create-dapp && changeset publish",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.5",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.0.0",
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yaml,yml}": [
      "prettier --write"
    ]
  }
}
