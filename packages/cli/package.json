{
  "name": "gzkdev/create-dapp",
  "author": "gzkdev",
  "version": "1.0.0",
  "type": "module",
  "description": "App scaffolding tool for web3",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "create-dapp": "./dist/index.js"
  },
  "files": [
    "./dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format:write": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.0.0",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@create-dapp/eslint-config": "workspace:*",
    "@create-dapp/ts-config": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.12.7",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
